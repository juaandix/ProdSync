# =============================================================
# ProdSync — Variables de entorno
#
# Copia este archivo como .env en la raíz del proyecto:
#   cp .env.example .env
#
# El archivo .env NUNCA debe subirse al repositorio.
# =============================================================

# --- PostgreSQL ---
# Credenciales de la base de datos.
# Si no se definen, docker-compose usará los valores por defecto (solo para desarrollo).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=prodsyncdb

# --- Anthropic (opcional) ---
# Necesaria solo si usas las funcionalidades de IA del backend.
# Obtén tu clave en https://console.anthropic.com
ANTHROPIC_API_KEY=
